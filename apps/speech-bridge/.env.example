# Khaya AI (GhanaNLP) — https://translation.ghananlp.org
KHAYA_API_KEY=your_khaya_api_key_here

# Budget alert threshold (percentage of monthly quota, 0-100)
BUDGET_ALERT_THRESHOLD=80

# Cache TTL in seconds (default: 7 days for translations, 30 days for TTS)
CACHE_TTL_TRANSLATE=604800
CACHE_TTL_TTS=2592000

# Active model registry (comma-separated, checked in order)
# Options: khaya, whisper-akan, gemma-tw, coqui-tw
ACTIVE_TRANSLATE_PROVIDERS=khaya
ACTIVE_STT_PROVIDERS=khaya
ACTIVE_TTS_PROVIDERS=khaya

# Self-hosted model endpoints (set when your own models are deployed)
# WHISPER_AKAN_URL=https://your-whisper-endpoint.com
# GEMMA_TW_URL=https://your-gemma-endpoint.com
# COQUI_TW_URL=https://your-coqui-endpoint.com
