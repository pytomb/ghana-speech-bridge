{
  "name": "@ghana-speech-bridge/i18n",
  "version": "0.1.0",
  "description": "Locale files and domain vocabulary packs for Ghanaian language apps — Twi, Ewe, Ga, Dagbani, Fante",
  "keywords": [
    "ghana",
    "twi",
    "akan",
    "ewe",
    "ga",
    "dagbani",
    "fante",
    "i18n",
    "localization",
    "west-africa",
    "nlp",
    "voice-native"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pytomb/ghana-speech-bridge",
    "directory": "packages/ghana-i18n"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./locales/*": "./locales/*.json",
    "./domains/*": "./domains/*.json"
  },
  "files": [
    "dist",
    "locales",
    "domains"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
